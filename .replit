modules = ["python-3.11"]

run = "python main.py"

[agent]
expertMode = true

[nix]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Website"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
# Di sini perubahannya: menambahkan bash github_sync.sh;
args = "bash gitea_sync.sh; bash github_sync.sh; python main.py"

[[workflows.workflow]]
name = "Start Website"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python web.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
